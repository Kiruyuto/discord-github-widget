{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "pull-request-title-pattern": "chore(${component}): Release ${version}",
  "group-pull-request-title-pattern": "chore(ci): Release ${version}",
  "separate-pull-requests": false,
  "prerelease": false,
  "draft-pull-request": true,
  "pull-request-header": "Changelog",
  "include-v-in-tag": false,
  "packages": {
    ".": {
      "component": "discord-github-widget",
      "changelog-path": "CHANGELOG.md",
      "release-type": "simple",
      "extra-files": [
        {
          "type": "xml",
          "path": "Directory.Build.props",
          "xpath": "//Project/PropertyGroup/Version"
        }
      ]
    }
  },
  "plugins": [
    "sentence-case"
  ],
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features",
      "hidden": false
    },
    {
      "type": "fix",
      "section": "Bug Fixes",
      "hidden": false
    },
    {
      "type": "ci",
      "section": "CI/CD",
      "hidden": false
    },
    {
      "type": "chore",
      "section": "Chores & Maintenance",
      "hidden": false
    },
    {
      "type": "docs",
      "section": "Documentation",
      "hidden": false
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": false
    },
    {
      "type": "style",
      "section": "Style",
      "hidden": false
    },
    {
      "type": "refactor",
      "section": "Refactors",
      "hidden": false
    },
    {
      "type": "perf",
      "section": "Performance",
      "hidden": false
    }
  ]
}
